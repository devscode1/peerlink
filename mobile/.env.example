# Mobile app configuration

# Signaling Server
SIGNALING_SERVER_URL=http://localhost:3000
# SIGNALING_SERVER_URL=https://peerlink-signaling.fly.dev (production)

# Display settings
DEFAULT_DISPLAY_NAME=Anonymous
DARK_MODE_ENABLED=true

# TURN Server (optional)
# CUSTOM_TURN_URL=turn:turn.example.com:3478
# CUSTOM_TURN_USERNAME=username
# CUSTOM_TURN_CREDENTIAL=credential

# Features
ENABLE_FILE_TRANSFER=true
ENABLE_MESSAGE_HISTORY=true
ENABLE_DEBUG_LOGGING=false
