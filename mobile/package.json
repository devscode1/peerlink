    "expo": "~51.0.0",
    "expo-av": "~14.0.0",
    "expo-document-picker": "~12.0.0",
    "expo-file-system": "~17.0.0",
    "expo-media-library": "~16.0.0",
    "expo-secure-store": "~13.0.0",
    "expo-sqlite": "~14.0.0",
    "expo-status-bar": "~1.12.1",
    "fast-glob": "^3.3.3",
    "graphql": "^16.8.1",
    "joi": "^18.2.1",
    "js-sha256": "0.11.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
